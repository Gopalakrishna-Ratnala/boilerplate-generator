# Dependencies
node_modules/

# Logs
*.log
npm-debug.log*

# OS artifacts
.DS_Store
Thumbs.db

# Editor artifacts
.vscode/*
!.vscode/extensions.json
.idea/

# Angular / build artifacts (in case `ng`/`generate.js` is ever run from inside this
